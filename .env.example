# Copy to .env for local dev. Docker compose sets its own values.
SECRET_KEY=dev-change-me

# Database. Defaults to local SQLite if unset. Docker uses Postgres.
# DATABASE_URL=postgresql+psycopg2://thoth:thoth@localhost:5432/thoth
DATABASE_URL=sqlite:///thoth.db

# Celery / Redis. If CELERY_BROKER_URL is unset, tasks run EAGER (inline),
# so the app is fully runnable locally without Redis.
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/1
# REDIS_URL=redis://localhost:6379/2

# Where per-workspace files (custom wordlists, exports) live.
DATA_DIR=./data
